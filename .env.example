# ============================================
# Player Passport — Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# --- PostgreSQL ---
POSTGRES_USER=pp_user
POSTGRES_PASSWORD=pp_password
POSTGRES_DB=playerpassport

# --- API ---
DATABASE_URL=postgresql://pp_user:pp_password@postgres:5432/playerpassport
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-api-key

# --- Clerk Authentication ---
CLERK_SECRET_KEY=sk_test_your-clerk-secret-key
CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-publishable-key
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-publishable-key

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Deployment (optional, for CI/CD) ---
# FLY_API_TOKEN=
# FLY_APP_NAME_STAGING=
# FLY_APP_NAME_PRODUCTION=
# VERCEL_TOKEN=
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=
